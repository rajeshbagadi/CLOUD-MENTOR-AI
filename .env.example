# 1. API Keys & Credentials
# Google Gemini API Key (Required for model connectivity validation and generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Backup standard API key parameter
GOOGLE_API_KEY=your_gemini_api_key_here

# 2. Ingestion Settings (Defaults)
# Maximum characters size per chunk split
CHUNK_SIZE=1000
# Chunk overlap window
CHUNK_OVERLAP=200
